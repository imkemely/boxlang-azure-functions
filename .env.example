# =============================================================================
# BoxLang Azure Functions - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — your credentials stay local.
# =============================================================================

# Azure deployment target (used by Maven plugin and Azure CLI)
AZURE_FUNCTION_APP_NAME=boxlang-func-dev
AZURE_REGION=eastus
AZURE_RESOURCE_GROUP=boxlang-rg-dev

# Optional: Azure authentication for deployment from inside the container
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=